# データベース（変更不要）
DATABASE_URL=sqlite+aiosqlite:///./alarm.db

# アプリのルートパス（nginxリバースプロキシ経由の場合: /alarm-clock など）
ROOT_PATH=

# リッスンポート（uvicorn起動時に使用）
PORT=8001

# OpenRouter API Key（VOICE_BACKEND=openrouter の場合に必要）
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# 音声アシスタントのバックエンド
# claude_cli  : Claude Code CLI（要: claude コマンドのログイン済み環境）
# openrouter  : OpenRouter API経由
# ollama      : ローカルOllama
VOICE_BACKEND=claude_cli

# --- Ollama使用時のみ ---
# OLLAMA_URL=http://192.168.100.xxx:11434
# VOICE_MODEL=llama3

# --- Dify使用時のみ ---
# VOICE_BACKEND=dify
# DIFY_URL=http://192.168.100.xxx
# DIFY_API_KEY=app-xxxx
