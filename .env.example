# データベース（変更不要）
DATABASE_URL=sqlite+aiosqlite:///./alarm.db

# アプリのルートパス（リバースプロキシ経由の場合: /alarm-clock など）
ROOT_PATH=

# リッスンポート
PORT=8001

# 音声文字起こしバックエンド
# openai : OpenAI Whisper API（whisper-1）
# groq   : Groq Whisper API（whisper-large-v3・無料枠あり）
# local  : faster-whisper ローカル（GPU環境向け）
STT_BACKEND=openai

# OpenAI APIキー（STT_BACKEND=openai の場合に必要）
OPENAI_API_KEY=sk-xxxx

# Groq APIキー（STT_BACKEND=groq の場合に必要）
# https://console.groq.com でAPIキーを取得
# GROQ_API_KEY=gsk_xxxx

# 音声アシスタントのバックエンド
# dify        : Dify API（推奨）
# openrouter  : OpenRouter API経由
# ollama      : ローカルOllama
# claude_cli  : Claude Code CLI（要ログイン済み環境）
VOICE_BACKEND=dify

# --- Dify設定（VOICE_BACKEND=dify の場合に必要） ---
# Dify Cloud を使う場合（推奨・どこからでも動く）
DIFY_URL=https://api.dify.ai
# セルフホスト Dify を使う場合
# DIFY_URL=http://192.168.100.xxx
DIFY_API_KEY=app-xxxx

# --- OpenRouter使用時のみ ---
# VOICE_BACKEND=openrouter
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# --- Ollama使用時のみ ---
# VOICE_BACKEND=ollama
# OLLAMA_URL=http://192.168.100.xxx:11434
# VOICE_MODEL=llama3
